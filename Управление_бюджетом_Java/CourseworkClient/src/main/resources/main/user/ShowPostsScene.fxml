<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="postsListPane" prefHeight="434.0" prefWidth="500.0" style="-fx-background-color: #87cefa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.ui.user.ShowPosts">
      <children>
          <ToolBar layoutX="20.0" layoutY="26.0" nodeOrientation="LEFT_TO_RIGHT" prefHeight="40.0" prefWidth="459.0" style="-fx-background-color: #3baff7;">
              <items>
                  <Button fx:id="findPostButton" mnemonicParsing="false" onAction="#findPost" style="-fx-background-color: #0a9bf5;" text="Find/Refresh" />
                  <TextField fx:id="findPostField" prefHeight="26.0" prefWidth="88.0" promptText="post_id" />
            <ToolBar fx:id="crudToolbar" disable="true" nodeOrientation="RIGHT_TO_LEFT" prefHeight="0.0" prefWidth="258.0" style="-fx-background-color: #3baff7;" visible="false">
               <items>
                  <Button fx:id="deletePostButton" mnemonicParsing="false" onAction="#deletePost" style="-fx-background-color: #0a9bf5;" text="Delete" />
                  <Button fx:id="updatePostButton" mnemonicParsing="false" onAction="#updatePost" style="-fx-background-color: #0a9bf5;" text="Update" />
                  <Button fx:id="addPostButton" mnemonicParsing="false" onAction="#addPost" style="-fx-background-color: #0a9bf5;" text="Add" />
               </items>
            </ToolBar>
              </items>
          </ToolBar>
          <TableView fx:id="postTable" layoutX="20.0" layoutY="66.0" prefHeight="345.0" prefWidth="459.0">
              <columns>
                  <TableColumn fx:id="postIdColumn" prefWidth="55.20001220703125" text="post_id" />
                  <TableColumn fx:id="nameColumn" prefWidth="228.0" text="name" />
                  <TableColumn fx:id="priorityColumn" prefWidth="58.399932861328125" text="priority" />
                  <TableColumn fx:id="salaryColumn" prefWidth="118.39990234375" text="salary" />
              </columns>
          </TableView>
      </children>
  </AnchorPane>
