<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="departmentListPane" prefHeight="434.0" prefWidth="500.0" style="-fx-background-color: #87cefa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.ui.user.ShowDepartments">
      <children>
          <ToolBar layoutX="20.0" layoutY="21.0" nodeOrientation="LEFT_TO_RIGHT" prefHeight="46.0" prefWidth="459.0" style="-fx-background-color: #3baff7;">
              <items>
                  <Button fx:id="findDepartmentButton" mnemonicParsing="false" onAction="#findDepartment" style="-fx-background-color: #0a9bf5;" text="Find/Refresh" />
                  <TextField fx:id="findDepartmentField" prefHeight="26.0" prefWidth="96.0" promptText="department_id" />
            <ToolBar fx:id="crudToolbar" disable="true" nodeOrientation="RIGHT_TO_LEFT" prefHeight="0.0" prefWidth="258.0" style="-fx-background-color: #3baff7;" visible="false">
               <items>
                  <Button fx:id="deleteDepartmentButton" mnemonicParsing="false" onAction="#deleteDepartment" style="-fx-background-color: #0a9bf5;" text="Delete" />
                  <Button fx:id="updateDepartmentButton" mnemonicParsing="false" onAction="#updateDepartment" style="-fx-background-color: #0a9bf5;" text="Update" />
                  <Button fx:id="addDepartmentButton" mnemonicParsing="false" onAction="#addDepartment" style="-fx-background-color: #0a9bf5;" text="Add" />
               </items>
            </ToolBar>
              </items>
          </ToolBar>
          <TableView fx:id="departmentTable" layoutX="20.0" layoutY="66.0" prefHeight="345.0" prefWidth="459.0">
              <columns>
                  <TableColumn fx:id="departmentIdColumn" prefWidth="94.39996337890625" text="department_id" />
                  <TableColumn fx:id="nameColumn" prefWidth="273.59998321533203" text="name" />
                  <TableColumn fx:id="peopleCountColumn" prefWidth="88.800048828125" text="people count" />
              </columns>
          </TableView>
      </children>
  </AnchorPane>
