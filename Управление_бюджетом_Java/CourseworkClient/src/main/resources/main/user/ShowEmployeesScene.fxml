<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="accountListPane" prefHeight="434.0" prefWidth="500.0" style="-fx-background-color: #87cefa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.ui.user.ShowEmployees">
   <children>
      <ToolBar layoutX="20.0" layoutY="86.0" nodeOrientation="LEFT_TO_RIGHT" prefHeight="40.0" prefWidth="459.0" style="-fx-background-color: #3baff7;">
        <items>
            <Button fx:id="findEmployeeButton" mnemonicParsing="false" onAction="#findEmployee" style="-fx-background-color: #0a9bf5;" text="Find/Refresh" />
            <TextField fx:id="findEmployeeField" prefHeight="26.0" prefWidth="88.0" promptText="employee_id" />
            <ToolBar fx:id="crudToolbar" disable="true" nodeOrientation="RIGHT_TO_LEFT" prefHeight="0.0" prefWidth="258.0" style="-fx-background-color: #3baff7;" visible="false">
               <items>
                  <Button fx:id="deleteEmployeeButton" mnemonicParsing="false" onAction="#deleteEmployee" style="-fx-background-color: #0a9bf5;" text="Delete" />
                  <Button fx:id="updateEmployeeButton" mnemonicParsing="false" onAction="#updateEmployee" style="-fx-background-color: #0a9bf5;" text="Update" />
                  <Button fx:id="addEmployeeButton" mnemonicParsing="false" onAction="#addEmployee" style="-fx-background-color: #0a9bf5;" text="Add" />
               </items>
            </ToolBar>
        </items>
      </ToolBar>
      <TableView fx:id="employeeTable" layoutX="20.0" layoutY="126.0" prefHeight="286.0" prefWidth="459.0">
        <columns>
          <TableColumn fx:id="employeeIdColumn" prefWidth="76.0" text="employee_id" />
          <TableColumn fx:id="fullNameColumn" prefWidth="198.39997100830078" text="fullname" />
            <TableColumn fx:id="userIdColumn" prefWidth="47.20001220703125" text="user_id" />
            <TableColumn fx:id="postIdColumn" prefWidth="45.60003662109375" text="post_id" />
            <TableColumn fx:id="departmentIdColumn" prefWidth="91.199951171875" text="department_id" />
        </columns>
      </TableView>
      <Button fx:id="postDiagramButton" layoutX="132.0" layoutY="21.0" mnemonicParsing="false" onAction="#showPostDiagram" prefHeight="51.0" prefWidth="235.0" style="-fx-background-color: #0a9bf5;" text="Показать диаграмму распределения по должностям" textAlignment="CENTER" wrapText="true">
         <font>
            <Font name="Century" size="14.0" />
         </font>
      </Button>
   </children>
  </AnchorPane>
