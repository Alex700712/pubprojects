      </Label>
      <Label fx:id="roleLabel" layoutX="91.0" layoutY="135.0" prefHeight="23.0" prefWidth="226.0" text="Роль :">
         <font>
            <Font name="Century" size="16.0" />
         </font>
      </Label>
      <Label layoutX="136.0" layoutY="43.0" prefHeight="34.0" prefWidth="246.0" text="Данные пользователя">
         <font>
            <Font name="Century" size="20.0" />
