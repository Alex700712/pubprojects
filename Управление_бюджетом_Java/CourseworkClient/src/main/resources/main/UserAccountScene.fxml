<AnchorPane fx:id="accountPane" prefHeight="435.0" prefWidth="499.0" style="-fx-background-color: #87cefa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.ui.UserAccount">
