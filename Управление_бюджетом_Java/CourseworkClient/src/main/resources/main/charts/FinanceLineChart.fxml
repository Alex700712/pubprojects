<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="418.0" prefWidth="617.0" style="-fx-background-color: #87cefa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.ui.сharts.FinanceLineChart">
   <children>
      <LineChart fx:id="incomeLineChart" layoutX="-2.0" legendSide="TOP" prefHeight="352.0" prefWidth="619.0" title="&quot;Доходы/Расходы&quot;">
        <xAxis>
          <CategoryAxis side="BOTTOM" fx:id="xAxis" />
        </xAxis>
        <yAxis>
          <NumberAxis fx:id="yAxis" side="LEFT" />
        </yAxis>
      </LineChart>
      <Button fx:id="reportButton" layoutX="431.0" layoutY="352.0" mnemonicParsing="false" onAction="#writeToFile" prefHeight="50.0" prefWidth="138.0" style="-fx-background-color: #0a9bf5;" text="Сохранить в виде текстового отчёта" textAlignment="CENTER" wrapText="true">
         <font>
            <Font name="Century" size="14.0" />
         </font>
      </Button>
      <TextField fx:id="nameField" layoutX="238.0" layoutY="352.0" promptText="Название файла отчёта">
         <font>
            <Font size="13.0" />
         </font>
      </TextField>
      <Button fx:id="readButton" layoutX="46.0" layoutY="352.0" mnemonicParsing="false" onAction="#readFromFile" prefHeight="50.0" prefWidth="162.0" style="-fx-background-color: #0a9bf5;" text="Вывести данные отчёта на диаграмму" textAlignment="CENTER" wrapText="true">
         <font>
            <Font name="Century" size="14.0" />
         </font>
      </Button>
      <Label fx:id="nameError" layoutX="224.0" layoutY="384.0" style="-fx-text-fill: #ff0000;" text="Имя файла не может быть пустым" visible="false" />
      <Label fx:id="saveError" layoutX="242.0" layoutY="384.0" style="-fx-text-fill: #ff0000;" text="Ошибка сохранения в файл" visible="false" />
      <Label fx:id="readError" layoutX="249.0" layoutY="384.0" style="-fx-text-fill: #ff0000;" text="Ошибка чтения из файла" visible="false" />
   </children>
</AnchorPane>
