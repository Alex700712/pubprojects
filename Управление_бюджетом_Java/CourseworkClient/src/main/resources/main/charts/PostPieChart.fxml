<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="484.0" prefWidth="600.0" style="-fx-background-color: #87cefa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.ui.сharts.PostsPieChart">
   <children>
      <PieChart fx:id="postPieChart" layoutX="50.0" layoutY="4.0" prefWidth="500.0" title="Распределение сотрудников по должностям" />
      <Button fx:id="reportButton" layoutX="422.0" layoutY="419.0" mnemonicParsing="false" onAction="#writeToFile" prefHeight="50.0" prefWidth="138.0" style="-fx-background-color: #0a9bf5;" text="Сохранить в виде текстового отчёта" textAlignment="CENTER" wrapText="true">
         <font>
            <Font name="Century" size="14.0" />
         </font>
      </Button>
      <TextField fx:id="nameField" layoutX="229.0" layoutY="419.0" promptText="Название файла отчёта">
         <font>
            <Font size="13.0" />
         </font>
      </TextField>
      <Label fx:id="nameError" layoutX="215.0" layoutY="452.0" style="-fx-text-fill: #ff0000;" text="Имя файла не может быть пустым" visible="false" />
      <Label fx:id="saveError" layoutX="233.0" layoutY="452.0" style="-fx-text-fill: #ff0000;" text="Ошибка сохранения в файл" visible="false" />
      <Button fx:id="readButton" layoutX="37.0" layoutY="419.0" mnemonicParsing="false" onAction="#readFromFile" prefHeight="50.0" prefWidth="162.0" style="-fx-background-color: #0a9bf5;" text="Вывести данные отчёта на диаграмму" textAlignment="CENTER" wrapText="true">
         <font>
            <Font name="Century" size="14.0" />
         </font>
      </Button>
      <Label fx:id="readError" layoutX="240.0" layoutY="452.0" style="-fx-text-fill: #ff0000;" text="Ошибка чтения из файла" visible="false" />
   </children>
</AnchorPane>
