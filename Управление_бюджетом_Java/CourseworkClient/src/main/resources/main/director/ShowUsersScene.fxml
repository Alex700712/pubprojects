<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="postsListPane" prefHeight="434.0" prefWidth="500.0" style="-fx-background-color: #87cefa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.ui.director.ShowUsers">
    <children>
        <ToolBar layoutX="20.0" layoutY="50.0" nodeOrientation="LEFT_TO_RIGHT" prefHeight="40.0" prefWidth="459.0" style="-fx-background-color: #3baff7;">
            <items>
                <Button fx:id="findUserButton" mnemonicParsing="false" onAction="#findUser" style="-fx-background-color: #0a9bf5;" text="Find/Refresh" />
                <TextField fx:id="findUserField" prefHeight="26.0" prefWidth="88.0" promptText="user_id" />
            <ToolBar fx:id="crudToolbar" disable="true" nodeOrientation="RIGHT_TO_LEFT" prefHeight="0.0" prefWidth="258.0" style="-fx-background-color: #3baff7;" visible="false">
               <items>
                  <Button fx:id="deleteUserButton" mnemonicParsing="false" onAction="#deleteUser" style="-fx-background-color: #0a9bf5;" text="Delete" />
                  <Button fx:id="updateUserButton" mnemonicParsing="false" onAction="#updateUser" style="-fx-background-color: #0a9bf5;" text="Update" />
               </items>
            </ToolBar>
            </items>
        </ToolBar>
        <TableView fx:id="userTable" layoutX="20.0" layoutY="90.0" prefHeight="322.0" prefWidth="459.0">
            <columns>
                <TableColumn fx:id="userIdColumn" prefWidth="67.20001029968262" text="user_id" />
                <TableColumn fx:id="loginColumn" prefWidth="278.3999710083008" text="login" />
                <TableColumn fx:id="roleColumn" prefWidth="113.60003662109375" text="role" />
            </columns>
        </TableView>
      <Label layoutX="8.0" layoutY="22.0" text="Регистрация пользователей происходит в меню добавления сотрудника">
         <font>
            <Font name="Century" size="14.0" />
         </font>
      </Label>
    </children>
</AnchorPane>
